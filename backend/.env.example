# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=replace-with-32-char-random-string
JWT_SECRET=replace-with-long-random-string
ACCESS_TOKEN_EXPIRE_HOURS=24
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/qard

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── RabbitMQ (Celery broker) ─────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# ── MinIO / S3 ───────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=qard-assets

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...

# ── JazzCash (Pakistan) ──────────────────────────────────────────────────────
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
JAZZCASH_ENV=sandbox

# ── Firebase FCM ─────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_JSON=path/to/serviceAccountKey.json

# ── Twilio (SMS OTP) ─────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1...

# ── MLflow (Day 5+) ──────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5001
